   "source": [
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import torch\n",
    "\n",
    "x = torch.randn(3, 3, 3)\n",
    "flattened = nn.Flatten()\n",
    "layer1 = nn.Linear(9, 3)\n",
    "layer2 = nn.Linear(3, 2)\n",
    "m = nn.Sequential(flattened, nn.ReLU(), layer1, nn.ReLU(), layer2)\n",
    "y = m(x)\n",
    "print(x)\n",
    "print(y.shape)\n",
    "print(y)"
   ]
  }
